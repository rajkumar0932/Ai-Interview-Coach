PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Optional: PostgreSQL (currently app uses in-memory store)
# DATABASE_URL=postgresql://user:pass@localhost:5432/ai_interview_coach

# Optional: OpenAI for richer AI interviewer and reply (falls back to built-in prompts if unset)
# OPENAI_API_KEY=sk-...

# Code execution (production must use Docker)
# USE_DOCKER_EXECUTION=true   (default) — run user code in ephemeral Docker container (secure)
# USE_DOCKER_EXECUTION=false  — run on host (INSECURE: only for local dev without Docker)
# EXECUTION_MEMORY_LIMIT=128m
# EXECUTION_TIMEOUT_MS=5000
